# Environment files
.env
depi project/.env
depi project/depi project/.env

# Python caching
__pycache__/
*.pyc
depi project/__pycache__/
depi project/depi project/__pycache__/
**/__pycache__/
**/*.pyc

# Project outputs (generated artwork, etc.)
outputs/
depi project/outputs/
depi project/depi project/outputs/
**/outputs/*.png
**/outputs/*.json

# Streamlit secrets
.streamlit/secrets.toml
depi project/.streamlit/secrets.toml

# IDEs & System files
.vscode/
.idea/
.ipynb_checkpoints/
*.DS_Store
Thumbs.db
